    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode"], //"cpu", "memory"
    "modules-center": ["sway/window"],
    "modules-right": [ "custom/vpn", "custom/updates", "pulseaudio", "network", "battery", "clock"],
